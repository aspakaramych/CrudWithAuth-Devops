{%raw%}
{
  "annotations": {"list": []},
  "editable": true,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Application RED Metrics",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus_local"},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 1},
      "id": 1,
      "targets": [{"expr": "sum(rate(http_requests_received_total[5m])) or on() vector(0)", "legendFormat": "Requests per sec", "refId": "A"}],
      "title": "Request Rate (R)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus_local"},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 1},
      "id": 2,
      "targets": [{"expr": "sum(rate(http_requests_received_total{code=~\"5..\"}[5m])) or on() vector(0)", "legendFormat": "Errors per sec", "refId": "A"}],
      "title": "Error Rate (E)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus_local"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 1},
      "id": 3,
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95 Latency", "refId": "A"}],
      "title": "Duration (D) - P95 Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 11,
      "title": "Host Key Metrics & Backup Status",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus_local"},
      "fieldConfig": {"defaults": {"unit": "percent"}},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 9},
      "id": 5,
      "targets": [{"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)", "legendFormat": "CPU Usage", "refId": "A"}],
      "title": "Host CPU Usage",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus_local"},
      "fieldConfig": {"defaults": {"unit": "percent"}},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 9},
      "id": 6,
      "targets": [{"expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "legendFormat": "RAM Usage", "refId": "A"}],
      "title": "Host RAM Usage",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus_local"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {"options": {"0": {"text": "FAILED", "color": "red"}, "1": {"text": "SUCCESS", "color": "green"}}, "type": "value"}
          ]
        }
      },
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 9},
      "id": 4,
      "targets": [{"expr": "backup_success", "legendFormat": "Backup Status", "refId": "A"}],
      "title": "Database Backup Status",
      "type": "stat"
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "title": "Consolidated App RED & Host Metrics",
  "uid": "app-red-metrics"
  
}
{%endraw%}
