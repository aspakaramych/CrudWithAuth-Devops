global:
  resolve_timeout: 5m

route:
  group_by: ['alertname']
  group_wait: 10s
  group_interval: 1m
  repeat_interval: 1h
  receiver: 'telegram'

receivers:
- name: 'telegram'
  telegram_configs:
  - bot_token: '{{ telegram_bot_token }}'
    chat_id: {{ telegram_chat_id }}
    parse_mode: 'HTML'
    message: |
      {% raw %}
      <b>Status: {{ .Status | ToUpper }}</b>
      {{ range .Alerts }}
      <b>Alert:</b> {{ .Annotations.summary }}
      <b>Description:</b> {{ .Annotations.description }}
      <b>Severity:</b> {{ .Labels.severity }}
      <b>Started:</b> {{ .StartsAt.Format "15:04:05" }}
      {{ end }}
      {% endraw %}
