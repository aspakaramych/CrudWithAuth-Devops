[Unit]
Description=CrudWithAuth
After=network.target postgresql.service

[Service]
WorkingDirectory={{ app_dir }}
ExecStart={{ dotnet_path }} {{ app_dir }}/CrudWithAuth.dll
Restart=on-failure
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=crudwithauth-dotnet
User={{ app_user }}
StandardOutput=append:/var/log/crudwithauth/app.log
StandardError=append:/var/log/crudwithauth/error.log