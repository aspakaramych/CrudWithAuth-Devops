from flask import Flask, request
import logging

app = Flask(__name__)
logging.basicConfig(filename='/var/log/webhook_receiver.log', level=logging.INFO, format='%(asctime)s %(message)s')

@app.route('/alert', methods=['POST'])
def alert():
    payload = request.get_json(silent=True)
    app.logger.info('Webhook alert received: %s', payload)
    return '', 204

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=9000)
